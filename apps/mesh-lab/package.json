{
  "name": "@lofi/mesh-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/build-wasm.mjs",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node scripts/build-wasm.mjs",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit --pretty false && node --check src/audio/mesh-worklet.js",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
